// Ignition Advance - Cranking Mode
// Render: dot -Tpng -Gdpi=150 ign_cranking.dot -o ign_cranking.png
//
// Per-cylinder stage: see ign_percyl graph

digraph ign_cranking {
    rankdir=TB;
    node [fontname="Helvetica", fontsize=12];
    edge [fontname="Helvetica", fontsize=10];
    nodesep=1.5;
    ranksep=0.5;

    // ========== Detail box ABOVE (term 1: cranking) ==========
    d_cranking [shape=box, style=filled, fillcolor=lightyellow, label=<
        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>Cranking Advance</B></TD></TR>
        <TR><TD>Fixed advance during engine cranking</TD></TR>
        <TR><TD>based on coolant temperature at shutdown</TD></TR>
        <TR><TD> </TD></TR>
        <TR><TD><FONT COLOR="red">ign adv cranking</FONT></TD></TR>
        </TABLE>
    >];

    // ========== Main formula ==========
    formula [shape=none, label=<
        <TABLE BORDER="0" CELLSPACING="8" CELLPADDING="6">
        <TR>
            <TD><B>advance (Cranking)</B></TD>
            <TD><B>=</B></TD>
            <TD PORT="cranking"><B>cranking</B></TD>
            <TD><B>=</B></TD>
            <TD><FONT COLOR="dodgerblue" POINT-SIZE="9">OBD Mode $01 PID $0E</FONT></TD>
        </TR>
        </TABLE>
    >];

    // ========== Legend ==========
    legend [shape=plaintext, label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3" COLOR="gray60">
        <TR><TD COLSPAN="2"><B>Legend</B></TD></TR>
        <TR><TD BGCOLOR="lightyellow" WIDTH="16"> </TD><TD ALIGN="LEFT">CAL_ lookup</TD></TR>
        <TR><TD WIDTH="16"> </TD><TD ALIGN="LEFT"><FONT COLOR="red">CAL_ parameter</FONT></TD></TR>
        </TABLE>
    >];

    // ========== Layout ==========
    {rank=min; d_cranking}
    {rank=max; legend}

    // ========== Edges ==========
    d_cranking -> formula:cranking [arrowhead=vee, arrowsize=0.8];
}
